# PlantDoc — Environment variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────────────────────
# (No required keys — the app runs without any API keys)

# ── Optional: Gemini AI recommendations ──────────────────
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=

# ── Model paths (defaults work out of the box) ────────────
YOLO_MODEL_PATH=model/leaf_detector.pt
LEAF_CONFIDENCE_THRESHOLD=0.60

# ── Server settings ───────────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_ORIGINS=*
